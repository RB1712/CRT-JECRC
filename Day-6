#include <iostream>
using namespace std;

int main(){
    int a=10;
    int b=20;
    int c;
    cout<<"A: "<<a<<"B: "<<b;
    int *tempA = &a;
    int *tempB = &b;
    
    cout<<"\n";
    
    c=*tempA;
    a=*tempB;
    b=c;
    cout<<"After swapping: \n"<<"A:"<<a<<" B: "<<b;
    
}

