#include <iostream>
using namespace std;

void coffeeOrder(int coffee){
    int orderValue, Discount;
    orderValue=100*coffee;
    Discount=orderValue*10/100;
    cout<<"Your bill after discount is "<<orderValue-Discount<<"\n";
}

int main(){
    int coffee;
    cout<<"How many cups of coffee, you would like to order(INR 100/cup? ";
    cin>>coffee;
    
    coffeeOrder(coffee);
    return 0;
}

