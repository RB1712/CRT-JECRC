//Forming a square

#include <iostream>
using namespace std;

int main(){
    int a,c;
    cout<<"Enter the size:";
    cin>>a;
    c=(a-1);

    system("clear");
    for (int i=1; i<=a; i++){
        
        if (i==1){
            for (int j=1; j<=a; j++){
                cout<<"*"<<" ";
            }
            cout<<"\n";
        }
        else if(i>=2 && i<=c){
             for (int b=1; b<=a; b++){
                 if (b==1 || b==a){
                     cout<<"*"<<" ";
                 }
                 else{
                     cout<<"  ";
                 }
            }
            cout<<"\n";
        }
        else{
            for (int j=1; j<=a; j++){
                cout<<"*"<<" ";
            }
            cout<<"\n";
        }
    }
}

